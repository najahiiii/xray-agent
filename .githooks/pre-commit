#!/usr/bin/env bash
set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
cd "$repo_root"

mapfile -t staged_go_files < <(git diff --cached --name-only --diff-filter=ACMR -- "*.go")

if (( ${#staged_go_files[@]} > 0 )); then
  echo "[pre-commit] formatting staged Go files"
  for file in "${staged_go_files[@]}"; do
    if [[ -f "$file" ]]; then
      gofmt -w "$file"
    fi
  done
  git add -- "${staged_go_files[@]}"
fi

echo "[pre-commit] running go vet"
go vet . ./internal/...

echo "[pre-commit] running go test"
go test . ./internal/...
